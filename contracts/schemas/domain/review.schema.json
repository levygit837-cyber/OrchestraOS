{
  "$id": "https://orchestraos.local/schemas/domain/review.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "gate_type",
    "status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "work_unit_id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "agent_session_id": { "type": "string", "minLength": 1 },
    "reviewer_agent_id": { "type": "string", "minLength": 1 },
    "gate_type": {
      "type": "string",
      "enum": ["hard", "soft", "policy"]
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "in_progress",
        "approved",
        "changes_requested",
        "needs_discussion"
      ]
    },
    "verdict_reason": { "type": "string" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "criteria_checked": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "passed"],
        "properties": {
          "criterion": { "type": "string", "minLength": 1 },
          "passed": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" }
  }
}
