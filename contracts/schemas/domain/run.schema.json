{
  "$id": "https://orchestraos.local/schemas/domain/run.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "task_id",
    "work_unit_id",
    "status",
    "attempt",
    "started_at",
    "finished_at",
    "result",
    "failure_reason"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "task_id": { "type": "string", "minLength": 1 },
    "work_unit_id": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "waiting_approval",
        "paused",
        "validating",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "attempt": { "type": "integer", "minimum": 1 },
    "started_at": { "type": "string", "format": "date-time" },
    "finished_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "result": {
      "type": ["string", "null"],
      "enum": ["succeeded", "failed", "cancelled", null]
    },
    "failure_reason": {
      "type": ["string", "null"]
    }
  }
}
