{
  "$id": "https://orchestraos.local/schemas/domain/prompt-snapshot.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptSnapshot",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "run_id",
    "work_unit_id",
    "agent_session_id",
    "system_prompt",
    "task_prompt",
    "combined_prompt",
    "system_prompt_hash",
    "task_prompt_hash",
    "combined_prompt_hash",
    "composition_hash",
    "category_signature",
    "fragment_refs",
    "assembly_order",
    "variables_applied",
    "count_used",
    "first_used_at",
    "last_used_at",
    "created_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "work_unit_id": { "type": "string", "minLength": 1 },
    "agent_session_id": { "type": "string", "minLength": 1 },
    "system_prompt": { "type": "string", "minLength": 1 },
    "task_prompt": { "type": "string", "minLength": 1 },
    "combined_prompt": { "type": "string", "minLength": 1 },
    "system_prompt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "task_prompt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "combined_prompt_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "composition_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "category_signature": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "fragment_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "version", "category", "kind", "order", "body_hash", "metadata_hash", "title"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "category": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "body_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "metadata_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
          "title": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assembly_order": { "type": "array", "items": { "type": "string" } },
    "variables_applied": { "type": "object" },
    "count_used": { "type": "integer", "minimum": 1 },
    "first_used_at": { "type": "string", "format": "date-time" },
    "last_used_at": { "type": "string", "format": "date-time" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
