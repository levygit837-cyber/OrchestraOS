{
  "$id": "https://orchestraos.local/schemas/domain/prompt-fragment.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptFragment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "category",
    "kind",
    "title",
    "priority",
    "exclusive_group",
    "body_hash",
    "metadata_hash",
    "body",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "category": {
      "type": "string",
      "enum": [
        "policy.global",
        "policy.autonomy",
        "repository.context",
        "persona",
        "operating_mode",
        "technical_domain",
        "tool_policy",
        "communication",
        "output_contract",
        "validation",
        "ledger",
        "task_template"
      ]
    },
    "kind": {
      "type": "string",
      "enum": [
        "global_policy",
        "repo_context",
        "autonomy_policy",
        "persona",
        "operating_mode",
        "technical_domain",
        "tool_policy",
        "communication",
        "output_contract",
        "validation",
        "ledger",
        "task_template"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "priority": { "type": "integer", "minimum": 0 },
    "exclusive_group": { "type": "string" },
    "body_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "metadata_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "body": { "type": "string", "minLength": 1 },
    "applies_when": { "type": "object" },
    "requires": { "type": "array", "items": { "type": "string" } },
    "conflicts_with": { "type": "array", "items": { "type": "string" } },
    "allows": { "type": "array", "items": { "type": "string" } },
    "denies": { "type": "array", "items": { "type": "string" } },
    "approval_required": { "type": "array", "items": { "type": "string" } },
    "autonomy_level": { "type": "integer", "minimum": 0, "maximum": 2 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
