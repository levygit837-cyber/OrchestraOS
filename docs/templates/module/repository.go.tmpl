// Repository handles {{MODULE_NAME}} persistence.
type Repository struct {
	db db.DBTX
}

// NewRepository creates a new {{MODULE_NAME}} repository.
func NewRepository(db db.DBTX) *Repository {
	return &Repository{db: db}
}

// Create inserts a new {{MODULE_NAME}}.
func (r *Repository) Create(entity *{{MODULE_NAME | Title}}) error {
	_, err := r.db.Exec(
		QueryInsert,
		entity.ID,
		entity.Status,
		entity.CreatedAt,
		entity.UpdatedAt,
	)
	if err != nil {
		return fmt.Errorf("failed to create {{MODULE_NAME}}: %w", err)
	}
	return nil
}

// GetByID retrieves a {{MODULE_NAME}} by ID.
func (r *Repository) GetByID(id string) (*{{MODULE_NAME | Title}}, error) {
	row := r.db.QueryRow(QueryGetByID, id)
	var entity {{MODULE_NAME | Title}}
	err := row.Scan(&entity.ID, &entity.Status, &entity.CreatedAt, &entity.UpdatedAt)
	if err != nil {
		if err == sql.ErrNoRows {
			return nil, nil
		}
		return nil, fmt.Errorf("failed to get {{MODULE_NAME}}: %w", err)
	}
	return &entity, nil
}
